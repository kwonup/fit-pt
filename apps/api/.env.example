# 실제 값은 이 파일이 아니라 apps/api/.env 에 넣으세요 (.env는 git에 커밋되지 않음).
# 이 파일(.env.example)은 git에 커밋되는 템플릿이므로 실제 키를 절대 넣지 마세요.

# Supabase (백엔드용 — service_role_key 포함, 절대 프론트에 노출 금지)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider 선택: openai | claude
AI_PROVIDER=openai

# OpenAI (AI_PROVIDER=openai 일 때 사용, 절대 프론트에 노출 금지)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (AI_PROVIDER=claude 일 때 사용, 절대 프론트에 노출 금지)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-8

# CORS 허용 Origin
FRONTEND_ORIGIN=http://localhost:3000
