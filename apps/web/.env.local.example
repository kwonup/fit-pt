# 실제 값은 이 파일이 아니라 apps/web/.env.local 에 넣으세요 (.env.local은 git에 커밋되지 않음).
# 이 파일(.env.local.example)은 git에 커밋되는 템플릿이므로 실제 키를 절대 넣지 마세요.

# Supabase (프론트엔드용 — anon key만 사용, service_role_key 금지)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# FastAPI 백엔드 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
